{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["pip install -r backend/requirements.txt"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["cp -r backend/. ."]
    }
  },
  "deploy": {
    "startCommand": "daphne -b 0.0.0.0 -p $PORT logographic_chat.asgi:application"
  }
}
