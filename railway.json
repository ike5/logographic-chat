{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "numBuilds": 1
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "cd backend && daphne -b 0.0.0.0 -p $PORT logographic_chat.asgi:application",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30,
    "healthcheckInterval": 10
  }
}
